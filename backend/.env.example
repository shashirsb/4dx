MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/?appName=Cluster0
DB_NAME=4dx_dashboard
SESSION_TTL_HOURS=24
# Comma-separated mobiles that receive role=admin on OTP login (Admin nav + /api/admin/*).
ADMIN_PHONES=9999900000,8888800000
OPENAI_API_KEY=
CLAUDE_API_KEY=
GOOGLE_API_KEY=
HF_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
OPENAI_MODEL=gpt-4o-mini
CLAUDE_MODEL=claude-3-5-haiku-20241022
GOOGLE_MODEL=gemini-2.0-flash
# When false (default), skip OpenAI/Claude/Google — use Ollama then heuristic fallback only.
# Alias: useLLM. Truthy values: true, 1, yes.
USE_LLM=false
LOCAL_LLM_ENABLED=true
LOCAL_LLM_PROVIDER=ollama
LOCAL_LLM_MODEL=llama3.2:1b
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_TIMEOUT_SECONDS=45
OLLAMA_CONNECT_TIMEOUT_SEC=2
OLLAMA_NUM_PREDICT=1024
# When true, OTP is returned in the login API response and demo admin phones are shown on the sign-in screen.
DEMO_OTP_MODE=true
APP_MODE=dev
